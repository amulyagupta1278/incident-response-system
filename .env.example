# OpenAI (ChatGPT / GPT-4o) — the LLM powering agent reasoning.
# Leave blank to run fully offline in heuristic mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
LLM_STRICT_MODE=true
OPENAI_TIMEOUT_SECONDS=20
LLM_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
MEMGRAPH_URI=bolt://127.0.0.1:7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=incident-knowledge
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8011,http://127.0.0.1:8011
BROWSER_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

APP_ENV=development
DEMO_MODE=true
PUBLIC_BASE_URL=http://localhost:8000
ADMIN_API_KEY=dev-admin-key
DATABASE_PATH=data/gateway.db
GATEWAY_WORKER_ENABLED=true
INGEST_API_KEYS=demo-project:dev-ingest-key
BROWSER_PUBLIC_KEYS=demo-project:dev-browser-key
INGEST_RATE_LIMIT_PER_MINUTE=120
MAX_INGEST_PAYLOAD_BYTES=262144
RAW_PAYLOAD_RETENTION_DAYS=0
BROWSER_ERROR_TRIGGER_COUNT=3
BROWSER_ERROR_TRIGGER_WINDOW_MINUTES=5
CONNECTOR_SIGNATURES_REQUIRED=false
GITHUB_WEBHOOK_SECRETS=demo-project:dev-github-webhook-secret
GITHUB_WEBHOOK_SECRET=
SUPABASE_WEBHOOK_SECRETS=demo-project:dev-supabase-webhook-secret
SUPABASE_WEBHOOK_SECRET=

SERVICE=payment-api
LOG_LEVEL=INFO
LIVE_LOGS_PATH=

# Optional: Slack or Discord incoming webhook for live war-room notifications
WAR_ROOM_WEBHOOK_URL=
