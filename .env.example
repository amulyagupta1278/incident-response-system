# LLM provider selection: openai | anthropic | auto (default)
# "auto" prefers OPENAI_API_KEY, then ANTHROPIC_API_KEY.
# With no key at all, the system runs in deterministic heuristic mode.
LLM_PROVIDER=auto

# OpenAI (used for router decisions, RCA reasoning, and report writing)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-8

ENVIRONMENT=development
LOG_LEVEL=INFO
