# OpenAI (ChatGPT / GPT-4o) — the LLM powering agent reasoning.
# Leave blank to run fully offline in heuristic mode.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
LLM_STRICT_MODE=true
OPENAI_TIMEOUT_SECONDS=20
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8011,http://127.0.0.1:8011

SERVICE=payment-api
LOG_LEVEL=INFO
LIVE_LOGS_PATH=

# Optional: Slack or Discord incoming webhook for live war-room notifications
WAR_ROOM_WEBHOOK_URL=
